     ]
    },
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a paragraph:  Ali and Omar are eating apples outside\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Words starting with vowels: ['Ali', 'and', 'Omar', 'are', 'eating', 'apples', 'outside']\n",
      "Total vowels: 16\n",
      "Average vowel-word length: 4.57\n"
     ]
